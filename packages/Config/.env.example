# Database
DATABASE_URL="postgresql://user:password@localhost:5432/drawify"

# JWT
JWT_SECRET="your-jwt-secret-here"

# Server
HTTP_PORT=3001
WS_PORT=8080

# Frontend
FRONTEND_URL="http://localhost:3000"

# GitHub OAuth
# Create an OAuth App at https://github.com/settings/developers
# Set the callback URL to: http://localhost:3000/api/v1/user/auth/github/callback
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
GITHUB_CALLBACK_URL="http://localhost:3000/api/v1/user/auth/github/callback"

# Google OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
# Set the redirect URI to: http://localhost:3000/api/v1/user/auth/google/callback
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/user/auth/google/callback"
